# DATASETS
# Ignore all CSV and JSON files no accidental giant datasets uploads
*.csv
*.json
*.xlsx
*.db
*.sqlite

# EXCEPTIONS: Allow the specific 10MB sample dataset required by the rubric
!sample_data.csv
!representative_sample.json

# Ignore full data folders but keep the folder structure
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

